# Cloudflare R2 配置（必需）
R2_ACCOUNT_ID=your_account_id
R2_BUCKET_NAME=your_bucket_name

# R2 公開 URL（如果 Bucket 是公開的）
R2_PUBLIC_URL=https://your_bucket_name.your_account_id.r2.cloudflarestorage.com

# R2 API 憑證（需要列出文件功能時必需）
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key

# R2 端點（可選，默認使用 Cloudflare 端點）
# R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# 子路徑部署配置（如果部署到子路徑，例如 waynspace.com/camera-drift-ntu）
# NEXT_PUBLIC_BASE_PATH=/camera-drift-ntu

# 靜態資源前綴（可選，用於 CDN）
# NEXT_PUBLIC_ASSET_PREFIX=https://cdn.example.com
