# Copy this file to .env (or .env.local) and fill in the values.
# See docs/setup-newsletter.md for how to obtain each value.

# ===================
# Google Analytics 4
# ===================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
GA4_PROPERTY_ID=
GA_SERVICE_ACCOUNT_EMAIL=
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ===================
# Site
# ===================
NEXT_PUBLIC_SITE_URL=https://waynspace.com

# ===================
# Newsletter — Resend
# ===================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=Wayn <hi@mail.waynspace.com>
MAIL_REPLY_TO=you@example.com

# Generate with: openssl rand -hex 32
# Used to manually trigger /api/notify-new-articles (cron uses CRON_SECRET).
NEWSLETTER_SECRET=

# Set to 1 to disable real sending (logs payloads instead). Leave empty for production.
# NEWSLETTER_DRY_RUN=1

# ===================
# Newsletter — Vercel Postgres
# ===================
# Populated automatically by `vercel env pull .env.local` after provisioning
# Vercel Storage → Postgres. Listed here for visibility only.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ===================
# Cloudflare R2 (image CDN)
# ===================
CF_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BASE_URL=https://img.example.com
R2_PREFIX=blog-post
RCLONE_REMOTE=r2
